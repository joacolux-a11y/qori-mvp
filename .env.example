# Copia este archivo a .env.local y rellena con tus credenciales de Supabase.
# Mientras estén vacías, la app usa un backend local (localStorage) — funciona igual.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Noticias económicas (sección "¿Qué está pasando?"). Consigue una key gratis en gnews.io.
# Si la dejas vacía, la app muestra titulares de ejemplo (demo).
VITE_GNEWS_KEY=

# Registro de gastos por voz (interpreta la frase con Gemini). Key gratis en aistudio.google.com.
# Si la dejas vacía, se usa un intérprete local simple como respaldo.
VITE_GEMINI_KEY=
